# Arbitrum DeFi Agent Skill - Environment Variables

# Required for write operations (swap execution, agent registration)
PRIVATE_KEY=0xyour_private_key_here

# Optional: Custom RPC URLs (defaults to public endpoints)
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Optional: HTTP server port (default 3000)
PORT=3000
